# 将本文件另存为 .env 并填入下面两个 key

# Mapbox access token（地图底图）。申请：https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_access_token_here

# ——— 云脑（agent 的大脑，只在服务端用，不进前端 bundle）———
# 优先用通义 Qwen（阿里云百炼 DashScope · OpenAI 兼容接口）。填了 DASHSCOPE_API_KEY 就自动切 Qwen。
# 申请：https://bailian.console.aliyun.com/  （开通后在「API-KEY」处获取）
DASHSCOPE_API_KEY=
# 云脑模型 id（以百炼控制台为准）：qwen-plus（稳，默认）/ qwen-max / qwen3.6-plus / qwen-turbo …
QWEN_MODEL=qwen-plus
# DashScope 接入点：国内默认；新加坡用 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek API key（回退云脑）：未配 DASHSCOPE_API_KEY 时才用它。两者都不填则走规则 fallback，UI 照常工作。
DEEPSEEK_API_KEY=

# 端侧模型（做选歌 / 选图 / 分类 / 嵌入 / 视觉打标）。不填用默认；都不可达时自动走规则兜底。
# 后端选择：auto(默认，优先 MNN 再 ollama 再 stub) | mnn | ollama | stub
EDGE_BACKEND=auto

# MNN sidecar（端侧 MNN-LLM 推理，推荐的端侧后端，部署见 deploy/edge-runtime/）。
# 留空则不启用 MNN（auto 时回落 ollama/stub）；起了 sidecar 后填它的地址即可切端侧、前端不改。
MNN_URL=
# 模型路径在 sidecar 侧配置(deploy/edge-runtime/serve.sh)，不在这里。

# ollama 本机后端（备选，本机 demo 用）。
OLLAMA_URL=http://localhost:11434
EDGE_MODEL=qwen3:0.6b
EDGE_VISION_MODEL=qwen2.5vl:3b
